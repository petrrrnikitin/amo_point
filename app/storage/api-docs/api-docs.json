{
    "openapi": "3.0.0",
    "info": {
        "title": "Dogs API",
        "description": "API for fetching dog breeds",
        "version": "1.0.0"
    },
    "servers": [
        {
            "url": "/api",
            "description": "API server"
        }
    ],
    "paths": {
        "/dogs": {
            "get": {
                "tags": [
                    "Dogs"
                ],
                "summary": "Get all dog breeds",
                "operationId": "bf7793e0edf79096c5185a150eed6271",
                "parameters": [
                    {
                        "name": "page",
                        "in": "query",
                        "required": false,
                        "schema": {
                            "type": "integer",
                            "default": 1
                        }
                    },
                    {
                        "name": "per_page",
                        "in": "query",
                        "required": false,
                        "schema": {
                            "type": "integer",
                            "default": 15
                        }
                    }
                ],
                "responses": {
                    "200": {
                        "description": "Paginated list of dog breeds",
                        "content": {
                            "application/json": {
                                "schema": {
                                    "properties": {
                                        "data": {
                                            "type": "array",
                                            "items": {
                                                "$ref": "#/components/schemas/DogResource"
                                            }
                                        },
                                        "links": {
                                            "type": "object"
                                        },
                                        "meta": {
                                            "type": "object"
                                        }
                                    },
                                    "type": "object"
                                }
                            }
                        }
                    }
                }
            }
        }
    },
    "components": {
        "schemas": {
            "DogResource": {
                "properties": {
                    "id": {
                        "type": "integer",
                        "example": 1
                    },
                    "name": {
                        "type": "string",
                        "example": "Labrador Retriever"
                    },
                    "temperament": {
                        "type": "string",
                        "example": "Kind, Outgoing, Agile",
                        "nullable": true
                    },
                    "weight": {
                        "properties": {
                            "metric": {
                                "type": "string",
                                "example": "25 - 36",
                                "nullable": true
                            },
                            "imperial": {
                                "type": "string",
                                "example": "55 - 80",
                                "nullable": true
                            }
                        },
                        "type": "object"
                    },
                    "life_span": {
                        "type": "string",
                        "example": "10 - 12 years",
                        "nullable": true
                    }
                },
                "type": "object"
            }
        }
    },
    "tags": [
        {
            "name": "Dogs",
            "description": "Dogs"
        }
    ]
}